# IronDesk Configuration Template
# Copy this to .env and fill in your values

# Server Port (Vercel ignores this — it manages ports internally)
PORT=5000

# JWT Auth Secret Key — use a long random string in production
JWT_SECRET=super-secret-key-change-this-in-production

# Neon PostgreSQL Connection String (obtain from Neon Dashboard -> Connection Details)
DATABASE_URL=postgres://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# (Optional) Your custom production domain — enables CORS for it
# Leave blank if using the default .vercel.app URL
FRONTEND_URL=https://your-custom-domain.com
