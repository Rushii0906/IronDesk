# IronDesk Configuration Template

# Server Port
PORT=5000

# JWT Auth Secret Key (any random string)
JWT_SECRET=super-secret-key-change-this-in-production

# Supabase Credentials (obtain from Supabase Settings -> API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anonymous-anon-key
