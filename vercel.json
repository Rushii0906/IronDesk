{
  "version": 2,
  "builds": [
    {
      "src": "server/src/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/server/src/index.js"
    },
    {
      "source": "/downloads/:path*",
      "destination": "/server/src/index.js"
    },
    {
      "source": "/:path*",
      "destination": "/client/:path*"
    }
  ]
}
